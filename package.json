{
  "name": "orion",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner",
    "build": "tsc && vite build --configLoader runner",
    "lint": "eslint frontend/src vite.config.ts eslint.config.js",
    "format": "prettier frontend ai AGENTS.md README.md PRIVACY.md package.json tsconfig.json tsconfig.node.json vite.config.ts eslint.config.js prettier.config.js src-tauri/tauri.conf.json --write",
    "format:check": "prettier frontend ai AGENTS.md README.md PRIVACY.md package.json tsconfig.json tsconfig.node.json vite.config.ts eslint.config.js prettier.config.js src-tauri/tauri.conf.json --check",
    "test": "vitest run --configLoader runner",
    "test:watch": "vitest --configLoader runner",
    "preview": "vite preview",
    "tauri": "tauri",
    "setup:local": "pwsh.exe -NoProfile -File scripts/Initialize-LocalBuild.ps1",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
